# ─────────────────────────────────────────────────────────────
# 2KDais environment
# Copy to .env and fill in. NEVER commit .env.
# ─────────────────────────────────────────────────────────────

# Payload — generate with: openssl rand -hex 32
PAYLOAD_SECRET=

# ── Supabase Postgres ────────────────────────────────────────
# Runtime (serverless/Vercel): the TRANSACTION pooler, port 6543.
#   Supabase Dashboard → Project Settings → Database → Connection string → "Transaction pooler"
DATABASE_URI=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres

# Migrations only: the DIRECT connection, port 5432 (no pgbouncer).
DATABASE_URI_DIRECT=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres

# ── Supabase API (realtime + storage) ────────────────────────
# Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://<ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Supabase Storage (S3-compatible) ─────────────────────────
# Supabase Dashboard → Project Settings → Storage → S3 Connection
S3_BUCKET=media
S3_REGION=<region>
S3_ENDPOINT=https://<ref>.storage.supabase.co/storage/v1/s3
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Public site URL (used for absolute links / og)
NEXT_PUBLIC_SERVER_URL=http://localhost:3000
